# ── LLM Provider ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Audit Trail ────────────────────────────────────────────────────────────────
AUDIT_DB_PATH=./audit_trail.db

# ── Pipeline Thresholds ────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIES=2
